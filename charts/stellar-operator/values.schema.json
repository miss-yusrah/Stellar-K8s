{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "description": "Container image repository"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "description": "Image pull policy"
        },
        "tag": {
          "type": "string",
          "description": "Image tag (defaults to chart appVersion)"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "secrets": {
      "type": "object"
    },
    "podAnnotations": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "resources": {
      "type": "object"
    },
    "autoscaling": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "arch": {
      "type": "string"
    },
    "podDisruptionBudget": {
      "type": "object"
    },
    "operator": {
      "type": "object",
      "properties": {
        "logLevel": {
          "type": "string",
          "enum": ["trace", "debug", "info", "warn", "error"]
        },
        "restApiEnabled": {
          "type": "boolean"
        },
        "restApiPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "metricsPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "watchNamespace": {
          "type": "string"
        }
      }
    },
    "sidecar": {
      "type": "object"
    },
    "forkDetector": {
      "type": "object"
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "restApiPort": {
          "type": "integer"
        },
        "metricsPort": {
          "type": "integer"
        }
      }
    },
    "defaultResources": {
      "type": "object"
    },
    "featureFlags": {
      "type": "object"
    },
    "security": {
      "type": "object"
    },
    "networkIsolation": {
      "type": "object"
    },
    "byzantineWatcher": {
      "type": "object"
    },
    "otel": {
      "type": "object"
    },
    "scpAnalytics": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
